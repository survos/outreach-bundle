{
    "name": "survos/outreach-bundle",
    "description": "Lightweight outreach CRM bundle for organizations, contacts, activities, and external system footprints.",
    "license": "MIT",
    "type": "symfony-bundle",
    "require": {
        "php": "^8.4",
        "api-platform/doctrine-orm": "^4.2",
        "doctrine/doctrine-bundle": "^3.0",
        "doctrine/orm": "^3.3",
        "survos/import-bundle": "^2.0",
        "survos/jsonl-bundle": "^2.0",
        "symfony/console": "^7.4||^8.0",
        "symfony/config": "^7.4||^8.0",
        "symfony/dependency-injection": "^7.4||^8.0",
        "symfony/http-kernel": "^7.4||^8.0",
        "symfony/string": "^7.4||^8.0"
    },
    "autoload": {
        "psr-4": {
            "Survos\\OutreachBundle\\": "src/"
        }
    },
    "suggest": {
        "symfony/serializer": "Useful when consuming the ApiPlatform resources from JSON clients."
    }
}
